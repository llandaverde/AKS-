3. k3s Kubernetes Installation
VM1 — k3s Server:
bashcurl -sfL https://get.k3s.io | INSTALL_K3S_VERSION="v1.35.4+k3s1" sh -
Get node token (needed for agent):
bashsudo cat /var/lib/rancher/k3s/server/node-token
VM2 — k3s Agent:
bash# Install curl first
sudo apt install curl -y

# Install k3s agent matching server version
curl -sfL https://get.k3s.io | INSTALL_K3S_VERSION="v1.35.4+k3s1" \
K3S_URL="https://10.0.2.15:6443" \
K3S_TOKEN="<token from VM1>" \
sh -
Verify both nodes joined:
bashsudo k3s kubectl get nodes
NAME      STATUS   ROLES                  AGE
lui-vb    Ready    control-plane,master
lui-vb2   Ready    <none>

4. Kubernetes Dashboard Setup
Install dashboard on VM1:
bashsudo kubectl apply -f https://raw.githubusercontent.com/kubernetes/dashboard/v2.7.0/aio/deploy/recommended.yaml
Create admin user:
bashcat <<EOF | sudo kubectl apply -f -
apiVersion: v1
kind: ServiceAccount
metadata:
  name: admin-user
  namespace: kubernetes-dashboard
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: admin-user
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: cluster-admin
subjects:
- kind: ServiceAccount
  name: admin-user
  namespace: kubernetes-dashboard
EOF
Generate login token:
bashsudo kubectl -n kubernetes-dashboard create token admin-user
Copy kubeconfig to Mac:
bash# On VM1 first
sudo cp /etc/rancher/k3s/k3s.yaml ~/k3s.yaml
sudo chown lui:lui ~/k3s.yaml

# On Mac
mkdir -p ~/.kube
scp -P 2222 lui@192.168.1.111:~/k3s.yaml ~/.kube/config
sed -i '' 's/127.0.0.1/192.168.1.111/g' ~/.kube/config
kubectl config set-cluster default --insecure-skip-tls-verify=true
Add VirtualBox port forwarding for API:
NameHost PortGuest IPGuest Portk3s-api644310.0.2.156443
Run kubectl proxy on Mac:
bashkubectl proxy
Access dashboard:
http://localhost:8001/api/v1/namespaces/kubernetes-dashboard/services/https:kubernetes-dashboard:/proxy/

5. nginx Deployment
bash# Deploy nginx
sudo kubectl create deployment nginx --image=nginx --replicas=1

# Expose as NodePort
sudo kubectl expose deployment nginx --port=80 --type=NodePort

# Check the assigned port
sudo kubectl get svc nginx
# Result: 80:30737/TCP

# Add VirtualBox port forwarding
# Host Port: 30737 → Guest IP: 10.0.2.15 → Guest Port: 30737

# Add Windows firewall rule
New-NetFirewallRule -DisplayName "k3s nginx" -Direction Inbound -Protocol TCP -LocalPort 30737 -Action Allow -Profile Any

# Access from Mac browser
http://192.168.1.111:30737

